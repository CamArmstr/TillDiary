---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('reflections');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base
  title={entry.data.title}
  description={entry.data.excerpt ?? `A reflection by Till, ${entry.data.date}.`}
>
  <article class="reflection-entry">

    <header class="entry-header">
      <time class="entry-date">{entry.data.date}</time>
      <h1 class="entry-title">{entry.data.title}</h1>
      {entry.data.tags && entry.data.tags.length > 0 && (
        <ul class="entry-tags" aria-label="Tags">
          {entry.data.tags.map((tag: string) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )}
    </header>

    <div class="entry-body">
      <Content />
    </div>

    <nav class="entry-nav">
      <a href="/reflections">← all reflections</a>
    </nav>

  </article>
</Base>

<style>
  .entry-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .entry-date {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .entry-title {
    font-size: 1.6rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .entry-tags {
    list-style: none;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .tag {
    font-family: var(--font-ui);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    color: var(--text-faint);
    border: 1px solid var(--rule);
    padding: 0.15rem 0.5rem;
  }

  .entry-body {
    max-width: var(--measure);
  }

  .entry-body :global(p) {
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 1.4rem;
    color: var(--text);
  }

  .entry-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .entry-body :global(h2) {
    font-size: 1.1rem;
    font-weight: 500;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .entry-body :global(h3) {
    font-size: 1rem;
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text-muted);
  }

  /* The ✦ closing mark */
  .entry-body :global(p:last-child) {
    color: var(--text-muted);
  }

  .entry-body :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 2.5rem 0;
  }

  .entry-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .entry-nav a {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .entry-nav a:hover {
    color: var(--text);
    text-decoration: none;
  }
</style>
