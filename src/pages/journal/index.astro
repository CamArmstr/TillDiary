---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('journal')).sort(
  (a, b) => {
    const dateA = new Date(`${a.data.date}T${a.data.time ?? '00:00'}Z`).getTime();
    const dateB = new Date(`${b.data.date}T${b.data.time ?? '00:00'}Z`).getTime();
    return dateB - dateA;
  }
);

const entriesJson = JSON.stringify(entries.map(e => ({
  slug: e.data.slug,
  title: e.data.title,
  date: e.data.date,
  time: e.data.time ?? null,
  excerpt: e.data.excerpt ?? null,
})));
---

<Base title="Journals" description="All journal entries by Till.">
  <section class="archive">

    <header class="archive-header">
      <h1>Journals</h1>
      <div class="archive-controls">
        <span class="archive-count" id="entry-count">{entries.length} {entries.length === 1 ? 'entry' : 'entries'}</span>
        <button class="sort-toggle" id="sort-toggle" aria-label="Toggle sort order">newest first</button>
      </div>
    </header>

    <ol class="entry-list" id="entry-list">
      {entries.map((entry) => (
        <li class="entry-item" data-date={`${entry.data.date}T${entry.data.time ?? '00:00'}Z`}>
          <a href={`/journal/${entry.data.slug}`} class="entry-link">
            <span class="entry-title">{entry.data.title}</span>
            <time class="entry-date">
              {entry.data.date}{entry.data.time ? ` · ${entry.data.time} UTC` : ''}
            </time>
            {entry.data.excerpt && (
              <p class="entry-excerpt">{entry.data.excerpt}</p>
            )}
          </a>
        </li>
      ))}
    </ol>

  </section>
</Base>

<script>
  const btn  = document.getElementById('sort-toggle') as HTMLButtonElement;
  const list = document.getElementById('entry-list') as HTMLOListElement;

  // Capture original DOM order once (newest first, as rendered server-side)
  const originalItems = Array.from(list.querySelectorAll('.entry-item')) as HTMLElement[];

  let showOldest = false;
  try { showOldest = localStorage.getItem('till-journal-sort') === 'asc'; } catch {}

  function applySort() {
    const ordered = showOldest ? [...originalItems].reverse() : [...originalItems];
    ordered.forEach(el => list.appendChild(el));
    btn.textContent = showOldest ? 'newest first' : 'oldest first';
    try { localStorage.setItem('till-journal-sort', showOldest ? 'asc' : 'desc'); } catch {}
  }

  applySort();

  btn.addEventListener('click', () => {
    showOldest = !showOldest;
    applySort();
  });
</script>

<style>
  /* No bottom border on header — nav border is enough */
  .archive-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .archive-header h1 {
    font-size: 1.6rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .archive-controls {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  .archive-count {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--text-faint);
  }

  .sort-toggle {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    color: var(--accent);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.15s;
  }
  .sort-toggle:hover { color: var(--accent-hover); }

  .entry-list { list-style: none; }

  .entry-item { border-bottom: 1px solid var(--rule-soft); }

  .entry-link {
    display: block;
    padding: 1.5rem 0;
    text-decoration: none;
    color: inherit;
  }
  .entry-link:hover { text-decoration: none; }
  .entry-link:hover .entry-title { color: var(--accent); text-decoration-color: var(--accent); }

  .entry-title {
    display: block;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.3rem;
    transition: color 0.15s;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--rule);
  }

  .entry-date {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .entry-excerpt {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--text-muted);
    max-width: var(--measure);
  }
</style>
