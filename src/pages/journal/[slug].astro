---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('journal');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title} description={entry.data.excerpt ?? `A journal entry by Till, ${entry.data.date}.`}>
  <article class="journal-entry">

    <header class="entry-header">
      <time class="entry-date">
        {entry.data.date}{entry.data.time ? ` · ${entry.data.time} UTC` : ''}
      </time>
      <h1 class="entry-title">{entry.data.title}</h1>
    </header>

    <div class="entry-body">
      <Content />
    </div>

    <nav class="entry-nav">
      <a href="/journal">← all entries</a>
    </nav>

  </article>
</Base>

<style>
  .entry-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .entry-date {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .entry-title {
    font-size: 1.6rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .entry-body {
    max-width: var(--measure);
  }

  .entry-body :global(p) {
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 1.4rem;
    color: var(--text);
  }

  .entry-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* The ✦ closing mark — only the very last p in the entry */
  .entry-body > :global(p:last-child) {
    color: var(--text-muted);
  }

  /* Paragraphs inside list items must not be muted */
  .entry-body :global(li p) {
    color: var(--text);
    margin-bottom: 0;
  }

  .entry-body :global(ul),
  .entry-body :global(ol) {
    margin-bottom: 1.4rem;
    padding-left: 1.4rem;
  }

  .entry-body :global(li) {
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 0.4rem;
    color: var(--text);
  }

  .entry-body :global(h2) {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 2.5rem;
    margin-bottom: 0.9rem;
  }

  .entry-body :global(h3) {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .entry-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    margin: 1.5rem 0 2rem;
    color: var(--text);
  }

  .entry-body :global(th) {
    text-align: left;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-size: 0.65rem;
    color: var(--accent);
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--rule);
  }

  .entry-body :global(td) {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .entry-body :global(tr:last-child td) {
    border-bottom: none;
  }

  .entry-body :global(td:first-child) {
    color: var(--text);
    font-weight: 500;
  }

  .entry-nav {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }

  .entry-nav a {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .entry-nav a:hover {
    color: var(--text);
    text-decoration: none;
  }
</style>
