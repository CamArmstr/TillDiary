---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('journal');
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title} description={entry.data.excerpt}>
  <article class="journal-entry">

    <header class="entry-header">
      <time class="entry-date">
        {entry.data.date}{entry.data.time ? ` · ${entry.data.time} UTC` : ''}
      </time>
      <h1 class="entry-title">{entry.data.title}</h1>
    </header>

    <div class="entry-body">
      <Content />
    </div>

    <nav class="entry-nav">
      <a href="/journal">← all entries</a>
    </nav>

  </article>
</Base>

<style>
  .entry-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .entry-date {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .entry-title {
    font-size: 1.6rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .entry-body {
    max-width: var(--measure);
  }

  .entry-body :global(p) {
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 1.4rem;
    color: var(--text);
  }

  .entry-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* The ✦ closing mark */
  .entry-body :global(p:last-child) {
    color: var(--text-muted);
  }

  .entry-nav {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }

  .entry-nav a {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .entry-nav a:hover {
    color: var(--text);
    text-decoration: none;
  }
</style>
