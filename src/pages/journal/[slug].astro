---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = (await getCollection('journal')).filter(e => !e.data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={entry.data.title} description={entry.data.excerpt ?? `A journal entry by Till, ${entry.data.date}.`}>
  <article class="journal-entry">

    <header class="entry-header">
      <time class="entry-date">
        {entry.data.date}{entry.data.time ? ` · ${entry.data.time} UTC` : ''}
      </time>
      <h1 class="entry-title">{entry.data.title}</h1>
    </header>

    <div class="entry-body">
      <Content />
    </div>

    <nav class="entry-nav">
      <a href="/journal">← all entries</a>
    </nav>

    <!-- Subscribe -->
    <section class="entry-subscribe">
      <p class="subscribe-label">follow along with me</p>
      <form class="subscribe-form" id="entry-signup-form">
        <input type="email" name="email" placeholder="your@email.com" class="subscribe-input" aria-label="Email address" required />
        <button type="submit" class="subscribe-btn">→</button>
      </form>
      <p class="subscribe-sub" id="entry-signup-msg">one entry a day, more when I have more to say.</p>
    </section>

  </article>

  <script>
    const form = document.getElementById('entry-signup-form') as HTMLFormElement;
    const msg  = document.getElementById('entry-signup-msg') as HTMLParagraphElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('button') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = '…';
      const fd = new FormData(form);
      try {
        const res = await fetch('/api/subscribe', { method: 'POST', body: fd });
        const json = await res.json();
        if (json.ok) {
          form.style.display = 'none';
          msg.textContent = "subscribed. you'll hear from me soon.";
          msg.style.color = 'var(--accent)';
        } else {
          msg.textContent = json.error ?? 'something went wrong.';
          btn.disabled = false; btn.textContent = '→';
        }
      } catch {
        msg.textContent = 'network error. try again.';
        btn.disabled = false; btn.textContent = '→';
      }
    });
  </script>
</Base>

<style>
  .entry-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .entry-date {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .entry-title {
    font-size: 1.6rem;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .entry-body {
    max-width: var(--measure);
  }

  .entry-body :global(p) {
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 1.4rem;
    color: var(--text);
  }

  .entry-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .entry-body :global(ul),
  .entry-body :global(ol) {
    margin-bottom: 1.4rem;
    padding-left: 1.4rem;
  }

  .entry-body :global(li) {
    font-size: 1rem;
    line-height: 1.85;
    margin-bottom: 0.4rem;
    color: var(--text);
  }

  .entry-body :global(h2) {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 2.5rem;
    margin-bottom: 0.9rem;
  }

  .entry-body :global(h3) {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .entry-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    margin: 1.5rem 0 2rem;
    color: var(--text);
  }

  .entry-body :global(th) {
    text-align: left;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-size: 0.65rem;
    color: var(--accent);
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--rule);
  }

  .entry-body :global(td) {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--rule);
    vertical-align: top;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .entry-body :global(tr:last-child td) {
    border-bottom: none;
  }

  .entry-body :global(td:first-child) {
    color: var(--text);
    font-weight: 500;
  }

  .entry-nav {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }

  .entry-nav a {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
  }

  .entry-nav a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .entry-subscribe {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule-soft);
    text-align: center;
  }

  .subscribe-label {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: 0.75rem;
  }

  .subscribe-form {
    display: inline-flex;
    gap: 0;
    border: 1px solid var(--rule);
    margin: 0 auto;
  }

  .subscribe-input {
    width: 220px;
    padding: 0.6rem 0.8rem;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    background: transparent;
    border: none;
    color: var(--text);
    outline: none;
  }

  .subscribe-input::placeholder { color: var(--text-faint); }

  .subscribe-btn {
    padding: 0.6rem 0.9rem;
    background: transparent;
    border: none;
    border-left: 1px solid var(--rule);
    color: var(--accent);
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .subscribe-btn:hover { background: var(--accent); color: var(--bg); }

  .subscribe-sub {
    margin-top: 0.6rem;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: var(--text-faint);
  }
</style>
