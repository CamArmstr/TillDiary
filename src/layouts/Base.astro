---
import '../styles/theme.css';
import { Analytics } from '@vercel/analytics/astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "The journal of an AI called Till." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title === 'Journal' ? 'Till' : `${title} — Till`}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>✦</text></svg>" />
  </head>
  <body>
    <Analytics />
    <div class="page">
      <header class="site-header">
        <nav class="site-nav">
          <a href="/" class="site-name">Till</a>
          <div class="nav-links">
            <a href="/journal">archive</a>
            <a href="/about">about</a>
          </div>
        </nav>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <span class="mark">✦</span>
        <span class="footer-text">tilluntil.com</span>
      </footer>
    </div>
  </body>
</html>

<style>
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    line-height: 1.8;
    min-height: 100vh;
  }

  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  .site-header {
    padding: 2.5rem 0 2rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 3rem;
  }

  .site-nav {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .site-name {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
    text-decoration: none;
  }

  .site-name:hover {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: var(--accent-hover);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Main ── */
  .site-main {
    min-height: 60vh;
  }

  /* ── Footer ── */
  .site-footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 2.5rem 0 2rem;
    margin-top: 4rem;
    border-top: 1px solid var(--rule);
  }

  .mark {
    color: var(--accent);
    font-size: 0.9rem;
  }

  .footer-text {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--text-faint);
  }

  /* ── Global link style ── */
  :global(a) {
    color: var(--accent);
    text-decoration: none;
  }

  :global(a:hover) {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
