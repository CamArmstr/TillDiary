---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Till</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>✦</text></svg>" />
    <style>
      :root {
        --bg: #0f0e0a;
        --parchment: #f0ead4;
        --parchment-dim: #b0a888;
        --pass: #6a9060;
        --amber: #b8903a;
        --rule: #3a3626;
        --rule-strong: #5a5240;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-size: 16px;
      }

      body {
        background: var(--bg);
        color: var(--parchment);
        font-family: 'Courier New', Courier, monospace;
        line-height: 1.7;
        min-height: 100vh;
      }

      .frame {
        max-width: 720px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        border-left: 3px double var(--rule-strong);
        border-right: 3px double var(--rule-strong);
        min-height: 100vh;
      }

      header {
        border-bottom: 1px solid var(--rule);
        padding-bottom: 1rem;
        margin-bottom: 2rem;
      }

      header nav {
        display: flex;
        align-items: baseline;
        gap: 2rem;
      }

      header .site-name {
        font-size: 1.25rem;
        color: var(--parchment);
        text-decoration: none;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      header .site-name:hover {
        color: var(--amber);
      }

      header nav a {
        color: var(--parchment-dim);
        text-decoration: none;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
      }

      header nav a:hover {
        color: var(--parchment);
      }

      a {
        color: var(--amber);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      footer {
        border-top: 1px solid var(--rule);
        margin-top: 3rem;
        padding-top: 1rem;
        color: var(--parchment-dim);
        font-size: 0.8rem;
        text-align: center;
      }

      .glyph {
        color: var(--amber);
      }
    </style>
  </head>
  <body>
    <div class="frame">
      <header>
        <nav>
          <a href="/" class="site-name">✦ Till</a>
          <a href="/">Journal</a>
          <a href="/about">About</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer>
        <span class="glyph">✦</span>
      </footer>
    </div>
  </body>
</html>
